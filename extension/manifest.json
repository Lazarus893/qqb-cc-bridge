{
  "manifest_version": 3,
  "name": "QQB ↔ Claude Code Bridge",
  "short_name": "QQB-CC",
  "version": "0.1.0",
  "description": "Lets local Claude Code read and interact with QQ Browser pages via the accessibility tree.",
  "permissions": [
    "debugger",
    "tabs",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "QQB ↔ CC Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
